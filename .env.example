# PostgreSQL (docker-compose postgres service)
POSTGRES_USER=devtracker
POSTGRES_PASSWORD=devtracker_secret
POSTGRES_DB=devtracker
POSTGRES_PORT=5432

# Database connection (backend — use postgres host when running in Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=devtracker
DATABASE_PASSWORD=devtracker_secret
DATABASE_NAME=devtracker

# NestJS backend
NODE_ENV=development
PORT=3000
BACKEND_PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# JWT secrets (change in production)
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seeder (set to true on first run to seed demo data)
RUN_SEED=false

# NVIDIA API (NVIDIA AI integration)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_DEFAULT=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_CODE=nvidia/llama-3.1-nemotron-70b-instruct

# Email Configuration (Dev = MailHog, Prod = Gmail)
EMAIL_HOST=localhost         # smtp.gmail.com en prod
EMAIL_PORT=1025              # 587 en prod
EMAIL_USER=                  # ton.email@gmail.com en prod
EMAIL_PASS=                  # app password Gmail en prod (App Password Gmail, pas ton vrai MDP)
EMAIL_FROM=DevTracker <noreply@devtracker.local>

# Google Drive OAuth2 Backup & Storage
# (L'application utilise un fallback automatique local dans /local_drive_mock si non configuré)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=

# GitHub Sync Configuration
# (L'application utilise un simulateur local si non renseigné)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=ton_username
GITHUB_WEBHOOK_SECRET=change_this_secret
