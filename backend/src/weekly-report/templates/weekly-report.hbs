<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>DevTracker Weekly Report</title>
  <style>
    body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; padding: 40px; color: #333; }
    h1 { color: #2563eb; font-size: 28px; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px; }
    .summary { display: flex; gap: 20px; margin: 30px 0; }
    .stat-box { flex: 1; background: #f3f4f6; padding: 20px; border-radius: 8px; text-align: center; }
    .stat-value { font-size: 32px; font-weight: bold; color: #1d4ed8; }
    .stat-label { font-size: 14px; color: #6b7280; text-transform: uppercase; margin-top: 5px; }
    h2 { font-size: 20px; margin-top: 40px; color: #111827; }
    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
    th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #e5e7eb; }
    th { background-color: #f9fafb; font-weight: 600; color: #374151; }
    tr:nth-child(even) { background-color: #f9fafb; }
    .badge { display: inline-block; padding: 4px 8px; border-radius: 9999px; font-size: 12px; font-weight: 500; }
    .badge-done { background: #dcfce7; color: #166534; }
    .footer { margin-top: 50px; text-align: center; font-size: 12px; color: #9ca3af; }
  </style>
</head>
<body>
  <h1>DevTracker Weekly Report</h1>
  <p>Hello <strong>{{userName}}</strong>,</p>
  <p>Here is your productivity summary for the week of {{weekDate}}.</p>

  <div class="summary">
    <div class="stat-box">
      <div class="stat-value">{{completedTasksCount}}</div>
      <div class="stat-label">Tasks Completed</div>
    </div>
    <div class="stat-box">
      <div class="stat-value">{{totalHours}}</div>
      <div class="stat-label">Hours Logged</div>
    </div>
  </div>

  <h2>Completed Tasks</h2>
  <table>
    <thead>
      <tr>
        <th>Task</th>
        <th>Project</th>
        <th>Time Spent</th>
      </tr>
    </thead>
    <tbody>
      {{#each tasks}}
      <tr>
        <td><strong>{{title}}</strong></td>
        <td>{{projectName}}</td>
        <td>{{timeSpent}}</td>
      </tr>
      {{/each}}
      {{^tasks}}
      <tr>
        <td colspan="3" style="text-align: center; color: #9ca3af;">No tasks completed this week.</td>
      </tr>
      {{/tasks}}
    </tbody>
  </table>

  <div class="footer">
    Generated by DevTracker • Keep up the great work!
  </div>
</body>
</html>
